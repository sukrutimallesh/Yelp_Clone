{
  "version": 2,
  "builds": [
    { "src": "Client/package.json", "use": "@vercel/static-build", "config": { "distDir": "build", "buildCommand": "CI=false npm run build" } },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/Client/$1" }
  ]
}
